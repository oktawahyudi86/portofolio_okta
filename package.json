{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node -e \"import(require('node:url').pathToFileURL(require('node:path').resolve(require('node:path').dirname(process.env.npm_package_json), 'scripts/dev-vite.mjs')).href)\"",
    "dev:server": "node server.js",
    "dev:all": "node -e \"import(require('node:url').pathToFileURL(require('node:path').resolve(require('node:path').dirname(process.env.npm_package_json), 'scripts/dev-all.mjs')).href)\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "prod": "npm run build && npm run start",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "chalk": "^5.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-fetch": "^3.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
