    "clean": "node ./scripts/clean-dist.mjs",
    "lint": "node ./scripts/run-tsc.mjs --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
