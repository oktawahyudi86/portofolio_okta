{
  "name": "okta-portfolio",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.9.4",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-vite.mjs --host=0.0.0.0 --port=5173",
    "dev:server": "node ./scripts/run-entry.mjs ./server.js",
