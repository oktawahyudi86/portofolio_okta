# ===== GEMINI AI CONFIGURATION =====
# Google Gemini API Key (Server-side only)
# IMPORTANT: This is a SECRET and should NEVER be exposed to the client/browser
# Used by both server.js (dev) and api/chat.ts (production) for the /api/chat endpoint
# Get your free API key from: https://aistudio.google.com/app/apikey
# - Without this key, the AI will use graceful fallback responses from local Okta data
# - With this key, the AI will call Google Gemini API for enhanced responses
GEMINI_API_KEY=your_gemini_api_key_here

# ===== SITE CONFIGURATION =====
# Public site URL for canonical, Open Graph, and Twitter meta tags
# Use your production domain without a trailing slash
VITE_SITE_URL=https://oktawahyu.web.id

# ===== SERVER CONFIGURATION =====
# Server Port (optional, defaults to 3000)
# In development: npm run dev starts both Vite (port 5173) and this server (port 3000)
# The Vite dev server proxies /api/* requests to localhost:3000
PORT=3000

# ===== DEVELOPMENT NOTES =====
# Development:
#   - Run: npm run dev
#   - This starts both the Vite dev server AND Node.js server concurrently
#   - Frontend: http://localhost:5173
#   - API: http://localhost:3000/api/chat
#
# Production (Vercel):
#   - Static assets are served from dist/
#   - API calls are routed to api/chat.ts (Vercel Serverless Function)
#   - GEMINI_API_KEY is loaded from Vercel environment variables
